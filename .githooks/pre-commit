#!/bin/sh
# Git pre-commit hook to verify System Prompt coherence

# Check if PowerShell Core (pwsh) is available
if ! command -v pwsh &> /dev/null; then
    echo "⚠️  pwsh (PowerShell Core) not found - SP verification disabled"
    echo "    Install PowerShell Core to enable automatic verification:"
    echo "    https://github.com/PowerShell/PowerShell/releases"
    exit 0
fi

# Execute the PowerShell script
pwsh -Command "& { .\scripts\check-prompts-sync.ps1; exit $LASTEXITCODE }"

# Capture the exit code
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo "❌ Prompt desynchronizations detected - commit cancelled"
    echo "  Please fix the discrepancies before committing:"
    echo "  1. Run: pwsh scripts/check-prompts-sync.ps1"
    echo "  2. Fix the files indicated in docs/qa/SP-COHERENCE-*.md"
    echo "  3. Recommit"
    exit 1
fi

exit 0
