#!/usr/bin/env bash
# pre-receive hook for canonical docs GitFlow enforcement
# Location: .githooks/pre-receive
# Enable by running: git config core.hooksPath .githooks

set -euo pipefail

CANON_PATTERNS=(
  "docs/DOC-1-CURRENT.md"
  "docs/DOC-2-CURRENT.md"
  "docs/DOC-3-CURRENT.md"
  "docs/DOC-4-CURRENT.md"
  "docs/DOC-5-CURRENT.md"
)

# Minimum line counts by doc type
# Cumulative: DOC-1 (500), DOC-2 (500), DOC-4 (300)
# Release-specific: DOC-3 (100), DOC-5 (50)
declare -A MIN_LINES_CUMULATIVE=(
  ["DOC-1"]=500
  ["DOC-2"]=500
  ["DOC-3"]=100
  ["DOC-4"]=300
  ["DOC-5"]=50
)

# Check if any canonical docs were modified
check_canonical_docs() {
  local old_rev="$1"
  local new_rev="$2"
  local ref="$3"
  
  # Get list of modified files
  local modified_files
  modified_files=$(git diff --name-only "$old_rev" "$new_rev")
  
  # Check each canonical doc pattern
  for pattern in "${CANON_PATTERNS[@]}"; do
    if echo "$modified_files" | grep -q "$pattern"; then
      check_feature_branch "$old_rev" "$new_rev" "$pattern"
      check_doc_format "$new_rev" "$pattern"
    fi
  done
}

check_feature_branch() {
  local old_rev="$1"
  local new_rev="$2"
  local file="$3"
  
  # Get commits that introduced changes to this file
  local commits
  commits=$(git log --format=%H "$old_rev".."$new_rev" -- "$file")
  
  for commit in $commits; do
    # Check if commit is on a feature branch
    local branch
    branch=$(git branch --contains "$commit" --format='%(refname:short)' | grep -E '^feature/|^fix/' || true)
    
    if [[ -z "$branch" ]]; then
      # Check if this is a merge commit (from PR)
      local is_merge
      is_merge=$(git cat-file -t "$commit" 2>/dev/null)
      
      if [[ "$is_merge" != "commit" ]] || ! git log -1 --format=%P "$commit" | grep -q " "; then
        echo "ERROR: Canonical doc '$file' modified without feature branch" >&2
        echo "       Commit: $commit" >&2
        echo "       Use: git revert $commit && git cherry-pick -x $commit on a feature branch" >&2
        exit 1
      fi
    fi
  done
}

check_doc_format() {
  local rev="$1"
  local file="$2"
  
  # Get the doc content
  local doc_content
  doc_content=$(git show "$rev:$file" 2>/dev/null) || return 0
  
  # Extract doc name from path (e.g., "DOC-1" from "docs/DOC-1-CURRENT.md")
  local doc_name
  doc_name=$(echo "$file" | sed -n 's|docs/DOC-\([0-9]*\)-CURRENT.md|DOC-\1|p')
  
  # Check for cumulative flag in front matter
  local cumulative_flag
  cumulative_flag=$(echo "$doc_content" | sed -n '/^---$/,/^---$/p' | grep -i "cumulative:" | head -1 | sed 's/.*cumulative: *//i' | tr -d ' ')
  
  # Get line count of the doc
  local line_count
  line_count=$(echo "$doc_content" | wc -l)
  
  # Determine minimum lines based on cumulative flag and doc type
  local min_lines
  if [[ "$cumulative_flag" == "true" ]]; then
    # Cumulative docs have higher thresholds
    case "$doc_name" in
      DOC-1) min_lines=500 ;;
      DOC-2) min_lines=500 ;;
      DOC-3) min_lines=300 ;;
      DOC-4) min_lines=300 ;;
      DOC-5) min_lines=200 ;;
      *) min_lines=100 ;;
    esac
    if [[ "$line_count" -lt "$min_lines" ]]; then
      echo "ERROR: Canonical doc '$file' appears to be delta-based ($line_count lines, expected >= $min_lines for cumulative)" >&2
      echo "       Cumulative docs must include all content from previous releases" >&2
      exit 1
    fi
  else
    # Release-specific docs have lower thresholds
    # For DOC-3 and DOC-5 without cumulative:true, apply release-specific thresholds
    case "$doc_name" in
      DOC-3) min_lines=100 ;;
      DOC-5) min_lines=50 ;;
      *)
        # Unknown doc without cumulative flag - be lenient
        min_lines=50
        ;;
    esac
    if [[ "$line_count" -lt "$min_lines" ]]; then
      echo "ERROR: Canonical doc '$file' is too short ($line_count lines, expected >= $min_lines)" >&2
      exit 1
    fi
  fi
}

# Main
if [[ $# -eq 3 ]]; then
  check_canonical_docs "$1" "$2" "$3"
fi
