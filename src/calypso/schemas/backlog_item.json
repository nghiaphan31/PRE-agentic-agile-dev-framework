{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BacklogItem",
  "description": "Schema for a single backlog item in draft_backlog.json or final_backlog.json",
  "type": "object",
  "required": ["id", "title", "description", "acceptance_criteria", "source_experts", "priority", "phase"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique backlog item identifier",
      "pattern": "^BL-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["architecture_expert", "security_expert", "ux_expert", "qa_expert"]
      }
    },
    "priority": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "phase": {
      "type": "string",
      "pattern": "^PHASE-[A-Z]$"
    },
    "classification": {
      "type": "string",
      "enum": ["GREEN", "ORANGE"],
      "description": "Set by orchestrator_phase4.py (Devil's Advocate)"
    },
    "challenge": {
      "type": "string",
      "description": "Devil's Advocate challenge text (only for ORANGE items)"
    },
    "human_decision": {
      "type": ["string", "null"],
      "enum": ["ACCEPT", "REJECT", null],
      "description": "Human arbitration decision (set by apply_triage.py)"
    }
  }
}
